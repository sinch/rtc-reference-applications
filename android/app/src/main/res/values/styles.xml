<resources>

    <!-- Base application theme. Material 3, follows system day/night. -->
    <style name="AppTheme" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorPrimaryContainer">@color/md_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/md_on_primary_container</item>

        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_on_secondary</item>
        <item name="colorSecondaryContainer">@color/md_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/md_on_secondary_container</item>

        <item name="colorTertiary">@color/md_tertiary</item>
        <item name="colorOnTertiary">@color/md_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/md_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/md_on_tertiary_container</item>

        <item name="colorError">@color/md_error</item>
        <item name="colorOnError">@color/md_on_error</item>
        <item name="colorErrorContainer">@color/md_error_container</item>
        <item name="colorOnErrorContainer">@color/md_on_error_container</item>

        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorOnBackground">@color/md_on_background</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="colorSurfaceVariant">@color/md_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/md_on_surface_variant</item>
        <item name="colorOutline">@color/md_outline</item>
        <item name="colorOutlineVariant">@color/md_outline_variant</item>
        <item name="colorSurfaceContainerLow">@color/md_surface_container_low</item>
        <item name="colorSurfaceContainer">@color/md_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/md_surface_container_high</item>

        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="actionBarStyle">@style/Widget.SinchRefApp.ActionBar</item>
        <item name="actionBarTheme">@style/ThemeOverlay.SinchRefApp.ActionBar</item>

        <item name="textInputStyle">@style/Widget.SinchRefApp.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.SinchRefApp.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.SinchRefApp.Button.Outlined</item>
        <item name="materialCardViewStyle">@style/Widget.SinchRefApp.Card</item>

        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

    <style name="AlertDialogQQWarning" parent="ThemeOverlay.Material3.MaterialAlertDialog" />

    <!-- Action bar that blends with the surface. -->
    <style name="Widget.SinchRefApp.ActionBar" parent="Widget.Material3.Light.ActionBar.Solid">
        <item name="background">?attr/colorSurface</item>
        <item name="elevation">0dp</item>
        <item name="titleTextStyle">@style/TextAppearance.SinchRefApp.ActionBarTitle</item>
    </style>

    <style name="ThemeOverlay.SinchRefApp.ActionBar" parent="ThemeOverlay.Material3.ActionBar">
        <item name="colorControlNormal">?attr/colorOnSurface</item>
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TextAppearance.SinchRefApp.ActionBarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- Component styles -->
    <style name="Widget.SinchRefApp.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_small</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_small</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_small</item>
        <item name="boxCornerRadiusTopStart">@dimen/corner_small</item>
    </style>

    <style name="Widget.SinchRefApp.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/corner_xlarge</item>
        <item name="android:paddingStart">@dimen/space_l</item>
        <item name="android:paddingEnd">@dimen/space_l</item>
    </style>

    <style name="Widget.SinchRefApp.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/corner_xlarge</item>
    </style>

    <style name="Widget.SinchRefApp.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">@dimen/corner_xlarge</item>
    </style>

    <style name="Widget.SinchRefApp.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/corner_medium</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLow</item>
        <item name="contentPadding">@dimen/space_m</item>
    </style>

    <style name="Widget.SinchRefApp.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/corner_medium</item>
        <item name="contentPadding">@dimen/space_m</item>
    </style>

    <!-- Call-screen specific styles -->
    <style name="Widget.SinchRefApp.CallActionButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">@dimen/call_action_button</item>
        <item name="android:layout_height">@dimen/call_action_button</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconSize">28dp</item>
        <item name="cornerRadius">32dp</item>
    </style>

    <style name="Widget.SinchRefApp.CallActionButton.Decline">
        <item name="backgroundTint">@color/decline</item>
        <item name="iconTint">@color/onCallSurface</item>
    </style>

    <style name="Widget.SinchRefApp.CallActionButton.Accept">
        <item name="backgroundTint">@color/accept</item>
        <item name="iconTint">@color/onCallSurface</item>
    </style>

    <style name="Widget.SinchRefApp.CallActionButton.Toggle">
        <item name="backgroundTint">@color/callOverlayLight</item>
        <item name="iconTint">@color/onCallSurface</item>
    </style>

    <style name="Widget.SinchRefApp.CallActionButton.Hangup">
        <item name="android:layout_width">@dimen/call_primary_action_button</item>
        <item name="android:layout_height">@dimen/call_primary_action_button</item>
        <item name="backgroundTint">@color/decline</item>
        <item name="iconTint">@color/onCallSurface</item>
        <item name="cornerRadius">36dp</item>
        <item name="iconSize">32dp</item>
    </style>

    <style name="TextAppearance.SinchRefApp.CallState" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/onCallSurface</item>
        <item name="android:textSize">@dimen/text_call_state</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.SinchRefApp.CallName" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/onCallSurface</item>
        <item name="android:textSize">@dimen/text_call_name</item>
    </style>

    <style name="TextAppearance.SinchRefApp.BrandTitle" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textStyle">bold</item>
    </style>

</resources>
