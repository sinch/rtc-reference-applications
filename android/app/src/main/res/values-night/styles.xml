        <item name="colorOutline">@color/md_outline</item>
        <item name="colorOutlineVariant">@color/md_outline_variant</item>
        <item name="colorSurfaceContainerLow">@color/md_surface_container_low</item>
        <item name="colorSurfaceContainer">@color/md_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/md_surface_container_high</item>

        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="actionBarStyle">@style/Widget.SinchRefApp.ActionBar</item>
        <item name="actionBarTheme">@style/ThemeOverlay.SinchRefApp.ActionBar</item>

        <item name="textInputStyle">@style/Widget.SinchRefApp.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.SinchRefApp.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.SinchRefApp.Button.Outlined</item>
        <item name="materialCardViewStyle">@style/Widget.SinchRefApp.Card</item>

        <item name="android:fitsSystemWindows">true</item>
